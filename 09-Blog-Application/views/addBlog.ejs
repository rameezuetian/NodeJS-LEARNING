<%- include('./partials/head') %>
<%- include('./partials/nav') %>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="glass-panel p-4 p-md-5">
                <h2 class="fw-bold mb-4"><i class="fa-solid fa-pen-nib me-2 text-indigo"></i>Write a New Story</h2>

                <% if (locals.error) { %>
                    <div class="alert alert-custom d-flex align-items-center" role="alert">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i>
                        <div><%= error %></div>
                    </div>
                <% } %>

                <form action="/blog" method="POST" enctype="multipart/form-data">
                    <div class="form-group-custom">
                        <label for="coverImage" class="form-label-custom">Cover Image</label>
                        <input type="file" class="form-control form-control-custom" id="coverImage" name="coverImage" accept="image/*">
                        <div id="imagePreviewContainer" class="mt-3 d-none border border-secondary rounded overflow-hidden" style="max-height: 250px;">
                            <img id="imagePreview" src="#" alt="Preview" class="w-100 h-100" style="object-fit: cover;">
                        </div>
                    </div>

                    <div class="form-group-custom">
                        <label for="title" class="form-label-custom">Title</label>
                        <input type="text" class="form-control form-control-custom" id="title" name="title" required placeholder="Give your story a catchy title...">
                    </div>

                    <div class="form-group-custom">
                        <label for="body" class="form-label-custom">Content</label>
                        <textarea class="form-control form-control-custom" id="body" name="body" rows="10" required placeholder="Once upon a time..."></textarea>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-4">
                        <a href="/" class="btn btn-custom-secondary">Cancel</a>
                        <button type="submit" class="btn btn-custom-primary">Publish Post</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    // Cover Image Live Preview
    const coverInput = document.getElementById('coverImage');
    const previewContainer = document.getElementById('imagePreviewContainer');
    const previewImg = document.getElementById('imagePreview');

    coverInput.addEventListener('change', function() {
        const file = this.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                previewImg.src = e.target.result;
                previewContainer.classList.remove('d-none');
            }
            reader.readAsDataURL(file);
        } else {
            previewContainer.classList.add('d-none');
        }
    });
</script>

<%- include('./partials/footer') %>
